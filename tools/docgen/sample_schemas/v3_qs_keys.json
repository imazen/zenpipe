          }
        },
        {
          "description": "Legacy quality fallback (0-100). Used when `qp` is not set.  RIAPI: `?quality=85` — sets a numeric quality as fallback for all codecs. Prefer `qp` (quality profile) for new code.",
          "key": "quality",
          "label": "Quality (legacy)",
          "param": "quality_fallback",
          "value_schema": {
            "default": 0.0,
            "maximum": 100.0,
            "minimum": 0.0,
            "type": "number"
          }
        },
        {
          "aliases": [
            "thumbnail"
          ],
          "description": "Explicit output format. Empty = auto-select from allowed formats.  Values: \"jpeg\", \"png\", \"webp\", \"gif\", \"avif\", \"jxl\", \"keep\", or \"\". \"keep\" preserves the source format. \"thumbnail\" is an alias for the key.",
          "key": "format",
          "label": "Output Format",
          "param": "format",
          "value_schema": {
            "default": "",
            "type": "string"
          }
        },
        {
          "aliases": [
            "qp.dppx",
            "dpr",
            "dppx"
          ],
          "description": "Device pixel ratio for quality adjustment.  Higher DPR screens tolerate lower quality (smaller pixels). Default 1.0 = no adjustment.",

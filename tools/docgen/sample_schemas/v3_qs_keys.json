          "param": "dpr",
          "value_schema": {
            "default": 1.0,
            "maximum": 10.0,
            "minimum": 0.5,
            "type": "number"
          }
        },
        {
          "description": "Global lossless preference. Empty = default (lossy).  Accepts \"true\", \"false\", or \"keep\" (match source losslessness).",
          "key": "lossless",
          "label": "Lossless",
          "param": "lossless",
          "value_schema": {
            "default": "",
            "type": "string"
          }
        },
        {
          "description": "Allow WebP output. Must be explicitly enabled.",
          "key": "accept.webp",
          "label": "Allow Webp",
          "param": "allow_webp",
          "value_schema": {
            "default": false,
            "type": "boolean"
          }
        },
        {

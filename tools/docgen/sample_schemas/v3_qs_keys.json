    "zencodecs.quality_intent": {
      "keys": [
        {
          "description": "Quality profile: named preset or numeric 0-100.  Named presets: \"lowest\", \"low\", \"medium_low\", \"medium\", \"good\", \"high\", \"highest\", \"lossless\". Numeric: \"0\" to \"100\" (codec-specific mapping).",
